# 依赖目录（Docker 内重新安装）
node_modules/
server/node_modules/
client/node_modules/

# 前端构建产物（Docker 内重新构建）
client/dist/

# 开发工具配置
.git/
.gitignore
*.md

# 环境变量（通过 env_file 或 --env-file 传入，不打包进镜像）
.env
.env.*

# SQLite 数据库文件（通过 volume 挂载）
server/data/*.db
server/data/*.sqlite

# 日志文件
*.log
logs/

# 测试文件
**/*.test.js
**/*.spec.js
coverage/

# 编辑器配置
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# Docker 配置本身（不需要打包进镜像）
Dockerfile
Dockerfile.nginx
docker-compose.yml
.dockerignore
# 注意：nginx.conf 需要被 COPY 进 nginx 镜像，不能排除
